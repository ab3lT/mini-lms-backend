# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_lms?schema=public"

# Secret used to sign JWTs - replace with a long random string in production
JWT_SECRET="replace-this-with-a-long-random-secret"

# JWT access token expiry (e.g. 15m, 1h, 7d)
JWT_EXPIRY="1d"

# Port the API listens on
PORT=3000

# Credentials used by prisma/seed.ts to create the initial Super Admin account.
# These are only read once, when the seed script runs.
SUPER_ADMIN_USERNAME="superadmin"
SUPER_ADMIN_PASSWORD="ChangeMe123!"
